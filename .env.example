# ---- Required in production ----

# Postgres connection string. On Railway, reference the database service:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# or, to use the no-egress internal network:
#   DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
DATABASE_URL=postgres://user:password@host:5432/dbname

# Finnhub API key for live US-equity quotes (free tier works). Get one at
# https://finnhub.io. Without it, the app runs but prices stay blank.
QUOTES_API_KEY=

# ---- Optional ----

# Quote provider. Only "finnhub" is implemented; the adapter is swappable.
# QUOTES_PROVIDER=finnhub

# Force Postgres SSL behaviour: "disable" or "require". Leave unset to
# auto-detect (no SSL for internal/localhost hosts, SSL otherwise).
# PGSSL=

# Dev only: where Vite proxies /api during `npm run dev`.
# API_DEV_TARGET=http://localhost:8080

# Port is provided by the platform in production; defaults to 8080 locally.
# PORT=8080
